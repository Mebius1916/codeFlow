{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@collaborative-editor/shared": ["../shared/src/index.ts"],
      "@collaborative-editor/shared/*": ["../shared/src/*"],
      "@collaborative-editor/yjs-local-forage": ["../yjsLocalForage/src/index.ts"],
      "@collaborative-editor/yjs-local-forage/*": ["../yjsLocalForage/src/*"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["react", "react-dom", "node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
