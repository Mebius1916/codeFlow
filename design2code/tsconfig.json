{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "@collaborative-editor/shared": ["../packages/shared/src/index.ts"],
      "@collaborative-editor/shared/*": ["../packages/shared/src/*"],
      "@collaborative-editor/yjs-local-forage": ["../packages/yjsLocalForage/src/index.ts"],
      "@collaborative-editor/yjs-local-forage/*": ["../packages/yjsLocalForage/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "../packages/editor/src/types/images.d.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules"]
}
