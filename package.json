{
  "name": "collaborative-code-editor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @codify/frontend dev",
    "build": "pnpm --filter @codify/agent build && pnpm --filter @codify/frontend build",
    "start": "pnpm --filter @codify/frontend start",
    "lint": "pnpm --filter @codify/frontend lint",
    "dev:all": "pnpm --filter @codify/frontend dev"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "pnpm": "^10.26.2"
  }
}
