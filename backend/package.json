{
  "name": "@codify/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"node --experimental-specifier-resolution=node --loader ts-node/esm src/main.ts\"",
    "build": "tsc --noEmit",
    "start": "node --experimental-specifier-resolution=node --loader ts-node/esm src/main.ts"
  },
  "dependencies": {
    "@codify/agent": "workspace:*",
    "@codify/design2code": "workspace:*",
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "dotenv": "^16.4.7",
    "puppeteer": "^24.42.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.50",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
