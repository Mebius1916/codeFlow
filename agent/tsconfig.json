{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "index.ts",
    "runtime/**/*.ts",
    "steps/**/*.ts",
    "prompts/**/*.ts",
    "llm/**/*.ts",
    "utils/**/*.ts",
    "interfaces/**/*.ts"
  ]
}
